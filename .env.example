# Neon Postgres — connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# Better Auth — generate secret: npx auth secret
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Cron — generate: openssl rand -hex 32
# Vercel sends this as Authorization: Bearer <CRON_SECRET> on scheduled runs.
# Optional: use https://cron-job.org (free) to hit /api/cron/sync-points more often.
CRON_SECRET=
